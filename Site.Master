<%@ Master Language="C#" AutoEventWireup="true"
    CodeFile="Site.master.cs"
    Inherits="karasustilyuzmecom.SiteMaster" %>

<!DOCTYPE html>
<html lang="tr">
<head runat="server">
    <title>Karasu Stil Yüzme Akademisi</title>

    <!-- META -->
