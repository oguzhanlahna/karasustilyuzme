                                <div class="d-none d-xl-block">
                                    <ul class="search-cart">
                                        <li class="search"><i class="fas fa-search"></i></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <!-- ===================== -->
    <!-- MAIN CONTENT -->
    <!-- ===================== -->
    <asp:ContentPlaceHolder ID="MainContent" runat="server" />


<!-- ===================== -->
<!-- CONTACT -->
<!-- ===================== -->
<section class="contact">
    <div class="container">
        <div class="section-wrapper row">
            <div class="col-lg-4 col-12">
                <div class="section-header">
                    <h3>Bilgi ve Kayıt Formu</h3>
                    <p>Yüzme kurslarımız hakkında bilgi almak veya kayıt olmak için formu doldurun, sizi arayalım.</p>
                </div>
            </div>

            <div class="col-lg-8 col-12">
                <div class="contact-form">

                    <asp:TextBox
                        ID="txtMasterName"
                        runat="server"
                        placeholder="Ad Soyad" />

                    <div class="cus_sel">
                        <asp:DropDownList
                            ID="ddlMasterCourse"
                            runat="server">
                            <asp:ListItem Text="Kurs Seçiniz" Value="" />
                            <asp:ListItem Text="Çocuk Yüzme" Value="Çocuk Yüzme" />
                            <asp:ListItem Text="Yetişkin Yüzme" Value="Yetişkin Yüzme" />
                            <asp:ListItem Text="Özel Ders" Value="Özel Ders" />
                            <asp:ListItem Text="Performans / Derece" Value="Performans / Derece" />
                        </asp:DropDownList>
                    </div>

                    <asp:TextBox
                        ID="txtMasterPhone"
                        runat="server"
                        placeholder="Telefon Numaranız" />

                    <asp:TextBox
                        ID="txtMasterEmail"
                        runat="server"
                        TextMode="Email"
                        placeholder="E-posta (İsteğe bağlı)" />

                    <asp:Button
                        ID="btnMasterSubmit"
                        runat="server"
                        CssClass="btn"
                        Text="Gönder"
                        OnClick="btnMasterSubmit_Click"
                        UseSubmitBehavior="false"
                        OnClientClick="this.disabled=true; this.value='Gönderiliyor...';" />

                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===================== -->
<!-- NEWSLETTER -->
<!-- ===================== -->
<section class="news-letter padding-tb">
    <div class="container">
        <div class="section-header">
            <h2>Kampanya ve Duyurular İçin Kayıt Olun</h2>
            <p>Yeni dönem yüzme kursları, özel ders programları ve kampanyalardan haberdar olun.</p>
        </div>

        <div class="section-wrapper">
            <div class="recent-news">

                <asp:TextBox
                    ID="txtNewsletterEmail"
                    runat="server"
                    TextMode="Email"
                    placeholder="E-posta adresiniz" />

                <asp:Button
                    ID="btnNewsletterSubmit"
                    runat="server"
                    CssClass="btn"
                    Text="Kayıt Ol"
                    OnClick="btnNewsletterSubmit_Click"
                    UseSubmitBehavior="false"
                    OnClientClick="this.disabled=true; this.value='Kaydediliyor...';" />

            </div>
        </div>
    </div>
</section>

    <!-- ===================== -->
    <!-- FOOTER -->
    <!-- ===================== -->
    <section class="footer padding-tb">
        <div class="container">
            <div class="section-wrapper">
                <div class="footer-top">
                    <div class="footer-rounding">
                        <div class="footer-logo">
                            <div class="footer-circle-wrapper"><div class="footer-circle"></div></div>
                            <div class="footer-circle-wrapper"><div class="footer-circle"></div></div>

                            <div class="logo-contact">
<a href="anasayfa.aspx">
  <img src="assets/images/logo/logo-footer.png"
       alt="Karasu Stil Yüzme"
       width="100"
       height="100"
       loading="lazy"
       decoding="async" />
</a>
                                <ul>
                                    <li><a href="mailto:akademi@karasustilyuzme.com">akademi@karasustilyuzme.com</a></li>
                                    <li><a href="tel:+905536640754">+90 553 664 0754</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="footer-content">
                        <div class="footer-item footer-about">
                            <h5>Menü</h5>
                            <ul>
                                <li><a href="anasayfa.aspx">Anasayfa</a></li>
                                <li><a href="hakkimizda.aspx">Hakkımızda</a></li>
                                <li><a href="kurslarimiz.aspx">Kurslarımız</a></li>
                                <li><a href="blog.aspx">Blog</a></li>
                                <li><a href="sikca-sorulan-sorular.aspx">Sık Sorulan Sorular</a></li>
                                <li><a href="bize-ulasin.aspx">Bize Ulaşın</a></li>
                            </ul>
                        </div>

                        <div class="footer-item footer-contact">
                            <h5>Biz Buradayız!</h5>
                            <span>Karasu Tesisimiz</span>
                            <p>Aziziye, Huzur Cd. No:6/1, 54500 Karasu/Sakarya, Türkiye</p>
                            <a href="https://www.google.com/maps/search/?api=1&query=Aziziye,+Huzur+Cd.+No:6/1,+54500+Karasu/Sakarya,+Türkiye"
                               target="_blank" rel="noopener">Google Haritalarda Bul</a>

                            <ul class="social-link-list d-flex flex-wrap">
                                <li><a href="https://www.facebook.com/karasustilyuzme" class="facebook" target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>
                                <li><a href="https://www.instagram.com/karasustilyuzme/" class="instagram" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>
                                <li><a href="https://tr.pinterest.com/karasustilyuzme/" class="pinterest" target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="footer-bottom">
                    <div class="fb-right">
                        <ul>
                            <li><a href="gizlilik-politikasi.aspx">Gizlilik Politikası</a></li>
                            <li><a href="sikca-sorulan-sorular.aspx">Sık Sorulan Sorular</a></li>
                        </ul>
                    </div>

                    <div class="fb-left">
                        <p>Copyright 2026 &copy; <a href="anasayfa.aspx">Karasu Stil Yüzme Eğitim Merkezi</a></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- scrollToTop start here -->
    <a href="#" class="scrollToTop"><i class="fas fa-angle-double-up"></i></a>
