    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FAVICONS -->
    <link rel="icon" type="image/png" sizes="32x32" href="assets/images/logo/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="assets/images/logo/favicon-16x16.png" />
    <link rel="shortcut icon" href="assets/images/logo/favicon.ico" />
    <link rel="apple-touch-icon" href="assets/images/logo/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;700;900&amp;family=Roboto:wght@300;400;500;700;900&amp;display=swap" rel="stylesheet" />

    <!-- CSS (TEMEL) -->
    <link rel="stylesheet" href="assets/css/bootstrap-grid.css" />
    <link rel="stylesheet" href="assets/css/all.min.css" />
    <link rel="stylesheet" href="assets/flaticon/flaticon.css" />
    <link rel="stylesheet" href="assets/css/animate.css" />
    <link rel="stylesheet" href="assets/css/swiper.min.css" />
    <link rel="stylesheet" href="assets/css/slick.css" />
    <link rel="stylesheet" href="assets/css/slick-theme.css" />
    <link rel="stylesheet" href="assets/css/lightcase.css" />
    <link rel="stylesheet" href="assets/css/jquery.nstSlider.css" />
    <link rel="stylesheet" href="assets/css/style.css" />

<style>
  /* Logo container sabitlenmişse ez */
  .header-section a.logo,
  .mobile-header a.logo {
    width: 250px !important;   /* istersen 220/260 yap */
    height: 100px !important;  /* logonun oranına göre */
    display: inline-flex !important;
    align-items: center !important;
    flex: 0 0 auto !important;
  }

  /* Görseli container’a göre ölçekle */
  .header-section a.logo img,
  .mobile-header a.logo img {
    width: 250px !important;
    height: 100px !important;
    object-fit: contain !important;
    display: block !important;
  }

  /* Header yüksekliği yetmiyorsa büyüt */
  .header-bottom { 
    min-height: 110px !important; 
  }

  .footer .logo-contact img{
  width:70px;
  height:70px;
  object-fit:contain;
}
</style>
</head>

<body>
<form id="form1" runat="server">

    <!-- ===================== -->
    <!-- MOBILE MENU -->
    <!-- ===================== -->
    <div class="mobile-menu">
        <nav class="mobile-header primary-menu d-xl-none">
            <div class="header-logo">
<img src="assets/images/logo/logo.png"
     width="250"
     height="100"
     alt="Karasu Stil Yüzme">
            </div>
            <div class="header-bar" id="open-button">
                <span></span><span></span><span></span>
            </div>
        </nav>

        <nav class="menu">
            <div class="mobile-menu-area d-xl-none">
                <div class="mobile-menu-area-inner" id="scrollbar">
                    <ul class="m-menu">
                        <li><a class="active" href="anasayfa.aspx">Anasayfa</a></li>
                        <li><a href="hakkimizda.aspx">Hakkımızda</a></li>
                        <li><a href="kurslarimiz.aspx">Kurslarımız</a></li>
                        <li><a href="blog.aspx">Blog</a></li>
                        <li><a href="sikca-sorulan-sorular.aspx">Sık Sorulan Sorular</a></li>
                        <li><a href="bize-ulasin.aspx">Bize Ulaşın</a></li>
                    </ul>

                    <ul class="social-link-list d-flex flex-wrap">
                        <li><a href="https://www.facebook.com/karasustilyuzme" class="facebook" target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>
                        <li><a href="https://www.instagram.com/karasustilyuzme/" class="instagram" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>
                        <li><a href="https://tr.pinterest.com/karasustilyuzme/" class="pinterest" target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </div>

    <!-- ===================== -->
    <!-- HEADER (DESKTOP) -->
    <!-- ===================== -->
    <header class="header-section d-none d-xl-block">
        <div class="header-top">
            <div class="container">
                <div class="htop-area row">
                    <div class="htop-left">
                        <p>Aziziye, Huzur Cd. No:6/1, 54500 Karasu/Sakarya, Türkiye</p>
                    </div>
                    <div class="htop-right">
                        <ul class="htop-information">
                            <li><a href="tel:+905536640754">+90 553 664 0754</a></li>
                            <li><a href="mailto:akademi@karasustilyuzme.com">akademi@karasustilyuzme.com</a></li>
                        </ul>
                        <ul class="social-link-list">
                            <li><a href="https://www.facebook.com/karasustilyuzme" target="_blank" rel="noopener"><i class="fab fa-facebook-f"></i></a></li>
                            <li><a href="https://www.instagram.com/karasustilyuzme/" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a></li>
                            <li><a href="https://tr.pinterest.com/karasustilyuzme/" target="_blank" rel="noopener"><i class="fab fa-pinterest"></i></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="header-bottom">
            <nav class="primary-menu">
                <div class="container">
                    <div class="menu-area">
                        <div class="row justify-content-between align-items-center">
                            <a href="anasayfa.aspx" class="logo">
                                <img src="assets/images/logo/logo.png" alt="Karasu Stil Yüzme Logo" width="190" height="60" loading="eager" fetchpriority="high" />
                            </a>

                            <div class="main-menu-area d-flex align-items-center">
                                <ul class="main-menu d-flex align-items-center">
                                    <li><a class="active" href="anasayfa.aspx">Anasayfa</a></li>
                                    <li><a href="hakkimizda.aspx">Hakkımızda</a></li>
